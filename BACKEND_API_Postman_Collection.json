    {
      "name": "10 - Review + Wishlist + Return + Reservation + Product Media",
      "item": [
        {
          "name": "Wishlist - Toggle Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/wishlists/{{productId}}"
          }
        },
        {
          "name": "Review - Create/Update",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"San pham tot\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/reviews/product/{{productId}}"
          }
        },
        {
          "name": "Return - Create Request (save returnRequestId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.request && data.request._id) pm.environment.set('returnRequestId', data.request._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"reason\": \"San pham loi\",\n  \"details\": \"Loi khoa keo\",\n  \"requestedAmount\": 100000\n}"
            },
            "url": "{{baseUrl}}/api/v1/returns"
          }
        },
        {
          "name": "Return - Admin Review",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Approved\",\n  \"adminNote\": \"Dong y\",\n  \"approvedAmount\": 100000,\n  \"refundTransactionId\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/returns/{{returnRequestId}}/review"
          }
        },
        {
          "name": "Reservation - Reserve (save reservationId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.reservation && data.reservation._id) pm.environment.set('reservationId', data.reservation._id);"
                ]
              }
            }
