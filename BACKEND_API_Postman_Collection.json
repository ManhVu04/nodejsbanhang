    {
      "name": "07 - Voucher",
      "item": [
        {
          "name": "Voucher - Create (save voucherId + voucherCode)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data._id) pm.environment.set('voucherId', data._id);",
                  "if (data && data.code) pm.environment.set('voucherCode', data.code);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SALE10\",\n  \"description\": \"Giam 10 phan tram\",\n  \"discountType\": \"PERCENT\",\n  \"discountValue\": 10,\n  \"minOrderValue\": 100000,\n  \"maxDiscount\": 50000,\n  \"usageLimit\": 100,\n  \"perUserLimit\": 1,\n  \"startsAt\": \"2026-04-01T00:00:00.000Z\",\n  \"expiresAt\": \"2026-12-31T23:59:59.000Z\",\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/vouchers"
          }
        },
        {
          "name": "Voucher - Validate",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/vouchers/validate/{{voucherCode}}?subtotal=299000"
          }
        }
      ]
    },
