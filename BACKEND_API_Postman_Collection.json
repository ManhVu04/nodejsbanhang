        {
          "name": "Category - List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/categories"
          }
        }
      ]
    },
    {
      "name": "03 - Product",
      "item": [
        {
          "name": "Product - Create (save productId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const pid = (data && data.product && data.product._id) ? data.product._id : (data && data._id ? data._id : '');",
                  "if (pid) pm.environment.set('productId', pid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tui Deo Cheo A\",\n  \"description\": \"Mo ta san pham\",\n  \"category\": \"{{categoryId}}\",\n  \"images\": [\"sample-product.webp\"],\n  \"price\": 299000,\n  \"sku\": \"SKU-A-001\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/products"
          }
        },
        {
          "name": "Product - Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}"
          }
        }
      ]
    },
